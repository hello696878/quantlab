# QuantLab backend — example environment configuration.
#
# Copy to `.env` (which is gitignored) and adjust locally. None of these are
# required for normal local development — QuantLab runs fully on static sample
# data with all of them unset.
#
# ---------------------------------------------------------------------------
# Global Markets Globe — optional FRED macro adapter (Phase 20.3)
# ---------------------------------------------------------------------------
# The Globe works completely without these. Leave FRED disabled unless you
# specifically want to enrich *macro* data for supported markets (US only in v1).
# Indices, FX, market structure, and news are always static sample data.
#
# Disabled by default. Set to "true" to allow optional macro enrichment.
GLOBE_FRED_ENABLED=false
#
# Your personal FRED API key (https://fred.stlouisfed.org/docs/api/api_key.html).
# NEVER commit a real key. Leave blank to keep static sample macro data even
# when GLOBE_FRED_ENABLED=true (the API will report "fred_unavailable").
FRED_API_KEY=
#
# Optional overrides (sensible defaults are used if unset):
# FRED_BASE_URL=https://api.stlouisfed.org/fred
# FRED_TIMEOUT_SECONDS=5
# GLOBE_FRED_CACHE_TTL_SECONDS=3600
