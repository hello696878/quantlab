# QuantLab backend — example environment configuration.
#
# Copy to `.env` (which is gitignored) and adjust locally. None of these are
# required for normal local development — QuantLab runs fully on static sample
# data with all of them unset.
#
# ---------------------------------------------------------------------------
# Global Markets Globe — optional FRED macro adapter (Phase 20.3)
# ---------------------------------------------------------------------------
# The Globe works completely without these. Leave FRED disabled unless you
# specifically want to enrich *macro* data for supported markets (US only in v1).
# FRED changes macro fields only. The quote adapter below separately controls
# supported primary index/FX rows; market structure and news remain static.
#
# Disabled by default. Set to "true" to allow optional macro enrichment.
GLOBE_FRED_ENABLED=false
#
# Your personal FRED API key (https://fred.stlouisfed.org/docs/api/api_key.html).
# NEVER commit a real key. Leave blank to keep static sample macro data even
# when GLOBE_FRED_ENABLED=true (the API will report "fred_unavailable").
FRED_API_KEY=
#
# Optional overrides (sensible defaults are used if unset):
# FRED_BASE_URL=https://api.stlouisfed.org/fred
# FRED_TIMEOUT_SECONDS=5
# GLOBE_FRED_CACHE_TTL_SECONDS=3600
#
# ---------------------------------------------------------------------------
# Global Markets Globe — optional delayed index / FX quote adapter (Phase 20.4)
# ---------------------------------------------------------------------------
# Disabled by default. When enabled, supported markets' PRIMARY index and FX
# fields may be enriched with DELAYED (never real-time) quotes via the project's
# existing free yfinance dependency. No API key. Fails closed to static sample
# data on any error. Indices/FX for unmapped markets, and news, stay static.
GLOBE_QUOTES_ENABLED=false
# Provider: "yfinance" (default, reuses the existing dependency). Any other value
# (e.g. "mock") leaves quotes unavailable → static fallback.
# GLOBE_QUOTES_PROVIDER=yfinance
# GLOBE_QUOTES_TIMEOUT_SECONDS=5
# GLOBE_QUOTES_CACHE_TTL_SECONDS=900
#
# ---------------------------------------------------------------------------
# Global Markets Globe — optional news-sentiment scaffold (Phase 20.5)
# ---------------------------------------------------------------------------
# Scaffold only — v1 always serves STATIC SAMPLE headlines. No live news, no
# scraping, no external news/LLM API, no API key. Disabled by default.
GLOBE_NEWS_ENABLED=false
# Provider: "static" (default, the bundled sample headlines). Any other value
# has no real provider wired in v1 → headlines stay static and source_status.news
# reports "news_unavailable" with a non-blocking warning.
# GLOBE_NEWS_PROVIDER=static
